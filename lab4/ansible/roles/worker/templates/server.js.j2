const http = require('http');
const { Client } = require('pg');

const dbClient = new Client({
  user: 'appuser',
  host: process.env.DB_HOST,
  database: 'appdb',
  password: 'apppassword',
  port: 5432,
});

dbClient.connect().catch(err => console.error('DB Connection Error:', err));

const server = http.createServer((req, res) => {
  if (req.url === '/health/alive') {
    res.writeHead(200);
    res.end('Alive\n');
  } else if (req.url === '/health/ready') {
    dbClient.query('SELECT 1')
      .then(() => {
        res.writeHead(200);
        res.end('Ready (DB Connected)\n');
      })
      .catch(() => {
        res.writeHead(500);
        res.end('DB Error\n');
      });
  } else {
    res.writeHead(200);
    res.end('Hello from Lab 4 App!\n');
  }
});

server.listen(3000, '127.0.0.1', () => {
  console.log('Server running on http://127.0.0.1:3000/');
});
